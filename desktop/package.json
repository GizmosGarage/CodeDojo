{
  "name": "codedojo-desktop",
  "version": "1.0.0",
  "description": "CodeDojo - AI-Powered Python Training Dojo",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "vite": "vite",
    "electron": "electron ."
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.1",
    "@monaco-editor/react": "^4.6.0",
    "framer-motion": "^10.18.0",
    "lucide-react": "^0.303.0",
    "vite": "^5.0.10",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.codedojo.app",
    "productName": "CodeDojo",
    "files": ["main.js", "preload.js", "dist/**/*"],
    "directories": {
      "output": "release"
    }
  }
}
